# Byte-compiled / optimized / DLL files
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Pytest and coverage
.pytest_cache/
.coverage
htmlcov/

# Local configuration & Secrets
.env
.env.*
!.env.example
.env.local
secrets/
credentials.json
*.pem
*.key
cloudflare.ini
docker-compose.override.yml

# Large directories / Application data
data/
# Ignore local cert material, but keep the corporate-CA staging dir (Scenario S3) so the
# Docker build context always has certs/extra-ca/ (else `COPY certs/extra-ca/` fails the build).
certs/*
!certs/README.md
!certs/extra-ca/
!certs/extra-ca/.gitkeep
!certs/extra-ca/*.crt
pgdata/
model_cache/

# Logs
*.log

