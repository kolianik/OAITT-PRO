# =============================================================================
# OAITT-PRO Deployment Configuration Template (.env.example)
# =============================================================================
# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Run ./prepare.sh before the first docker compose build (GigaAM weights).
# 3. Fill in HF_TOKEN, ADMIN_KEY, and POSTGRES_PASSWORD.
# 4. Set API_PUBLIC_HOST / API_UPLOAD_HOST and ports for your deployment.
# 5. Fill in Cloudflare credentials if using automatic wildcard SSL.
# See INSTALL.md for the full Ubuntu 24.04 LTS setup guide.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Hugging Face Authentication (Required for Diarization & WhisperX)
# -----------------------------------------------------------------------------
# Generate a READ access token at: https://huggingface.co/settings/tokens
# Ensure you accept the terms for:
# - https://huggingface.co/pyannote/speaker-diarization-community-1
# - https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=

# -----------------------------------------------------------------------------
# 2. System Administrative Authentication
# -----------------------------------------------------------------------------
# This API key grants global admin access to view all clients' analytics
ADMIN_KEY=

# -----------------------------------------------------------------------------
# 3. PostgreSQL Database Credentials
# -----------------------------------------------------------------------------
POSTGRES_DB=transcribe_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=generate_a_secure_db_password_here

# -----------------------------------------------------------------------------
# 4. SSL & Domain Configuration (Cloudflare DNS-01 Challenge)
# -----------------------------------------------------------------------------
# Required if you want automatic Let's Encrypt Wildcard Certificates via Nginx + Certbot
# Create a token with 'Zone:DNS:Edit' permissions in Cloudflare Dashboard
CLOUDFLARE_API_TOKEN=

# Your base domain (e.g., example.com)
# Certbot will issue certificates for: example.com and *.example.com
DOMAIN_NAME=yourdomain.com

# Email associated with your Let's Encrypt certificate registrations
EMAIL=your_email@example.com

# -----------------------------------------------------------------------------
# 5. Public API Hostnames (client-facing URLs in docs and integrations)
# -----------------------------------------------------------------------------
# Hostname for status, analytics, and health via CDN or standard HTTPS (port 443)
API_PUBLIC_HOST=oaitt.yourdomain.com

# Hostname for large file uploads (DNS-only / bypass CDN body limits)
# Often direct.<your-domain> pointing to the same server as API_PUBLIC_HOST
API_UPLOAD_HOST=direct.yourdomain.com

# -----------------------------------------------------------------------------
# 6. Port & Network Routing (host ports bound by Docker Compose)
# -----------------------------------------------------------------------------
# Nginx HTTP on the host: uploads, direct health checks.
# If your firewall exposes port 3000 publicly, set PROXY_PORT_HTTP=3000 here.
PROXY_PORT_HTTP=80

# Nginx HTTPS on the host (use 8443 when mapping external NAT to a custom port)
PROXY_PORT_HTTPS=443

# Gateway orchestrator — host port exposed only with: docker compose --profile debug up
GATEWAY_PORT=9000

# Shared secret for gateway -> inference internal API calls (openssl rand -hex 32)
INTERNAL_SERVICE_TOKEN=

# -----------------------------------------------------------------------------
# 7. Model & Performance Customization
# -----------------------------------------------------------------------------
WHISPERX_MODEL=bzikst/faster-whisper-large-v3-russian
GIGAAM_MODEL=v3_e2e_rnnt

# Target compute device (cuda or cpu)
DEVICE=cuda

# WhisperX compute type on CUDA: float16 only (quality policy; int8 is not supported)
WHISPERX_COMPUTE_TYPE=float16

# WhisperX transcribe batch size (lower values reduce VRAM use without changing model weights)
WHISPERX_BATCH_SIZE=4
