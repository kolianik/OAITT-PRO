# =============================================================================
# OAITT-PRO Deployment Configuration Template (.env.example)
# =============================================================================
# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Run ./prepare.sh before the first docker compose build (GigaAM weights).
# 3. Fill in HF_TOKEN, ADMIN_KEY, and POSTGRES_PASSWORD.
# 4. Set API_PUBLIC_HOST / API_UPLOAD_HOST and ports for your deployment.
# 5. Fill in Cloudflare credentials if using automatic wildcard SSL.
# See INSTALL.md for the full Ubuntu 24.04 LTS setup guide.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Hugging Face Authentication (Required for Diarization & WhisperX)
# -----------------------------------------------------------------------------
# Generate a READ access token at: https://huggingface.co/settings/tokens
# Ensure you accept the terms for:
# - https://huggingface.co/pyannote/speaker-diarization-community-1
# - https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=

# -----------------------------------------------------------------------------
# 2. System Administrative Authentication
# -----------------------------------------------------------------------------
# This API key grants global admin access to view all clients' analytics
ADMIN_KEY=

# -----------------------------------------------------------------------------
# 3. PostgreSQL Database Credentials
# -----------------------------------------------------------------------------
POSTGRES_DB=transcribe_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=generate_a_secure_db_password_here

# -----------------------------------------------------------------------------
# 4. SSL & Domain Configuration (Cloudflare DNS-01 Challenge)
# -----------------------------------------------------------------------------
# Required if you want automatic Let's Encrypt Wildcard Certificates via Nginx + Certbot
# Create a token with 'Zone:DNS:Edit' permissions in Cloudflare Dashboard
CLOUDFLARE_API_TOKEN=

# Your base domain (e.g., example.com)
# Certbot will issue certificates for: example.com and *.example.com
DOMAIN_NAME=yourdomain.com

# Email associated with your Let's Encrypt certificate registrations
EMAIL=your_email@example.com

# -----------------------------------------------------------------------------
# 5. Public API Hostnames (client-facing URLs in docs and integrations)
# -----------------------------------------------------------------------------
# Hostname for status, analytics, and health via CDN or standard HTTPS (port 443)
API_PUBLIC_HOST=oaitt.yourdomain.com

# Hostname for large file uploads (DNS-only / bypass CDN body limits)
# Often direct.<your-domain> pointing to the same server as API_PUBLIC_HOST
API_UPLOAD_HOST=direct.yourdomain.com

# -----------------------------------------------------------------------------
# 6. Port & Network Routing (host ports bound by Docker Compose)
# -----------------------------------------------------------------------------
# Nginx HTTP on the host: uploads, direct health checks.
# If your firewall exposes port 3000 publicly, set PROXY_PORT_HTTP=3000 here.
PROXY_PORT_HTTP=80

# Nginx HTTPS on the host (use 8443 when mapping external NAT to a custom port)
PROXY_PORT_HTTPS=443

# Gateway orchestrator — host port exposed only with: docker compose --profile debug up
GATEWAY_PORT=9000

# Shared secret for gateway -> inference internal API calls (openssl rand -hex 32)
INTERNAL_SERVICE_TOKEN=

# -----------------------------------------------------------------------------
# 7. Model & Performance Customization
# -----------------------------------------------------------------------------
WHISPERX_MODEL=bzikst/faster-whisper-large-v3-russian
# Russian Wav2Vec2 for WhisperX word-level alignment (Golos / Common Voice 8)
WHISPERX_ALIGN_MODEL=jonatasgrosman/wav2vec2-xls-r-1b-russian
GIGAAM_MODEL=v3_e2e_rnnt
GIGAAM_ALIGN_MODEL=jonatasgrosman/wav2vec2-xls-r-1b-russian
GIGAAM_BATCH_SIZE=4
GIGAAM_DENOISE=true
GIGAAM_DENOISE_MODEL=DeepFilterNet3
GIGAAM_DENOISE_DEVICE=cuda
# Windowed denoise: process audio in chunks to keep VRAM bounded (~1 GB peak regardless of file length).
# Lower GIGAAM_DENOISE_CHUNK_SEC to reduce VRAM; increase for faster throughput on cards with >10 GB.
GIGAAM_DENOISE_CHUNK_SEC=30
GIGAAM_DENOISE_OVERLAP_SEC=2
# Path inside the image where DeepFilterNet weights are baked at build time.
# Changing this is rarely needed; must match ARG GIGAAM_BAKED_DEEPFILTER_DIR in Dockerfile.
# GIGAAM_BAKED_DEEPFILTER_DIR=/opt/deepfilter
GIGAAM_ONNX_DIR=/app/data/gigaam_onnx
# ONNX precision: default FP32 (full precision). Set to true for opt-in FP16
# (less VRAM / faster on RTX 3060/3080; converts on CPU at bootstrap).
GIGAAM_ONNX_FP16=false
GIGAAM_OFFLINE_MODE=false
# Requires HF_TOKEN above. Without a token, GigaAM stays healthy for plain
# transcription but reports diarization_available=false and rejects diarize=true (HTTP 400).
GIGAAM_PREFETCH_DIARIZATION=true
# Pyannote segmentation batch size during diarization. Lower = less peak VRAM
# (e.g. 4 for RTX 3060 6 GB), slightly slower; higher = faster on roomier cards.
GIGAAM_DIARIZE_BATCH_SIZE=8

# Bootstrap download resilience: retry transient network failures with backoff
# before the attempt ends in `failed` (first-start hardening). 0 disables retries.
GIGAAM_BOOTSTRAP_RETRIES=3
GIGAAM_BOOTSTRAP_RETRY_DELAY=5

# Target compute device (cuda or cpu)
DEVICE=cuda

# WhisperX compute type on CUDA: float16 only (quality policy; int8 is not supported)
WHISPERX_COMPUTE_TYPE=float16

# WhisperX transcribe batch size (lower values reduce VRAM use without changing model weights)
WHISPERX_BATCH_SIZE=4

# -----------------------------------------------------------------------------
# 8. Network: proxy & corporate TLS interception (clean-install scenarios)
# -----------------------------------------------------------------------------
# You normally DO NOT set HTTP_PROXY/HTTPS_PROXY here by hand. The start/build
# scripts run scripts/netprep.{sh,ps1}, which:
#   * discovers the system proxy (env, Windows WinINET registry / WinHTTP, Linux
#     /etc/environment + apt.conf),
#   * probes direct reachability with the proxy bypassed and, if the internet is
#     reachable directly, DISABLES proxying (OAITT_PROXY_MODE=direct) — even when a
#     proxy is configured,
#   * if direct fails, translates a loopback proxy (http://127.0.0.1:<port>) to
#     http://host.docker.internal:<port> so containers/BuildKit can reach it
#     (OAITT_PROXY_MODE=translated), or passes a non-loopback proxy through
#     (OAITT_PROXY_MODE=passthrough).
# Set these only to FORCE a specific proxy (a non-loopback, container-reachable URL).
# A loopback value here is auto-translated by netprep; the Docker daemon's own image
# pulls still need daemon-level proxy config — see INSTALL.md "Network scenarios".
HTTP_PROXY=
HTTPS_PROXY=
# Hosts that must never be proxied. netprep computes a complete list (all internal
# service names + host.docker.internal + loopback + .local); override only to extend it.
NO_PROXY=

# Corporate transparent proxy with certificate substitution (MITM) — Scenario S3.
# 1. Run ./detect-corp-ca.sh   (or .\detect-corp-ca.ps1 on Windows). It probes a real
#    download endpoint and, if TLS is intercepted, stages the corporate root CA at
#    certs/extra-ca/corp-root-<fp>.crt and prints its SHA-256 fingerprint.
# 2. VERIFY that fingerprint with your IT department.
# 3. Set the flag below to 1 to trust the staged CA across image builds, container
#    runtime, and host-side prepare.py. Verification stays ON (the CA is ADDED, not
#    bypassed). Leaving it 0 (default) trusts NO corporate CA — fail-closed.
CORP_CA_AUTO_TRUST=0
